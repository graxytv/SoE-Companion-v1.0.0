{
  "productName": "SoECompanion",
  "version": "1.1.13",
  "identifier": "com.soecompanion.app",
  "build": {
    "beforeDevCommand": "corepack pnpm dev",
    "beforeBuildCommand": "corepack pnpm build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/sounds/*"
        ]
      }
    },
    "windows": [
      {
        "label": "main",
        "title": "SoE Companion",
        "width": 1040,
        "height": 740,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "overlay",
        "title": "SoE Companion Overlay",
        "width": 800,
        "height": 600,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "visible": false
      },
      {
        "label": "tracker-overlay",
        "title": "SoE Companion Tracker",
        "width": 360,
        "height": 620,
        "minWidth": 280,
        "minHeight": 320,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "skipTaskbar": false,
        "alwaysOnTop": false,
        "visible": false
      },
      {
        "label": "muling-banner",
